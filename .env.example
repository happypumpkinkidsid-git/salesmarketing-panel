# Copy to .env (gitignored) for local `netlify dev`, and set these in
# Netlify dashboard → Site settings → Environment variables for production.
#
# Get these from Supabase → Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SERVICE ROLE key — server-side only. NEVER expose to the browser.
# It is read by the Netlify function, which is the only thing that talks to Supabase.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
